{%- comment -%}
  GAINAGE Gallery — Mobile
  Scroll-snap horizontal gallery with arrow controls
  Usage: {% render 'gainage-gallery-mobile', product: product %}
{%- endcomment -%}

<div class="gainage-gallery-mobile" data-gallery-mobile>

  <div class="gainage-gallery-mobile__track">
    {%- for media in product.media -%}
      {%- if media.media_type == 'image' -%}
        <div class="gainage-gallery-mobile__slide">
          <img
            src="{{ media | image_url: width: 600 }}"
            alt="{{ media.alt | escape | default: product.title }}"
            width="600"
            height="{{ 600 | divided_by: media.aspect_ratio | round }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if product.media.size > 1 -%}
    <div class="gainage-gallery-mobile__thumbs">
      {%- for media in product.media -%}
        {%- if media.media_type == 'image' -%}
          <button type="button" class="gainage-gallery-mobile__thumb{% if forloop.first %} is-active{% endif %}" data-mobile-thumb="{{ forloop.index0 }}" aria-label="View image {{ forloop.index }}">
            <img
              src="{{ media | image_url: width: 120 }}"
              alt="{{ media.alt | escape | default: product.title }}"
              width="120"
              loading="lazy"
            >
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}

  {%- if product.media.size > 1 -%}
    <div class="gainage-gallery-mobile__controls">
      <button type="button" class="gainage-gallery-mobile__arrow gainage-gallery-mobile__arrow--prev" data-gallery-prev aria-label="Previous image">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button type="button" class="gainage-gallery-mobile__arrow gainage-gallery-mobile__arrow--next" data-gallery-next aria-label="Next image">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  {%- endif -%}
</div>
