{%- comment -%}
  GAINAGE Gallery — Desktop
  Horizontal scroll-snap carousel with arrow controls + thumbnails
  Usage: {% render 'gainage-gallery-desktop', product: product %}
{%- endcomment -%}

<div class="gainage-gallery-desktop" data-gallery>
  <!-- Carousel track -->
  <div class="gainage-gallery-desktop__track">
    {%- for media in product.media -%}
      {%- if media.media_type == 'image' -%}
        <div class="gainage-gallery-desktop__slide">
          <img
            src="{{ media | image_url: width: 1200 }}"
            srcset="{{ media | image_url: width: 800 }} 800w,
                    {{ media | image_url: width: 1000 }} 1000w,
                    {{ media | image_url: width: 1200 }} 1200w,
                    {{ media | image_url: width: 1500 }} 1500w"
            sizes="50vw"
            alt="{{ media.alt | escape | default: product.title }}"
            width="1200"
            height="{{ 1200 | divided_by: media.aspect_ratio | round }}"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
          >
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>

  {%- if product.media.size > 1 -%}
    <!-- Arrow controls -->
    <div class="gainage-gallery-desktop__controls">
      <button type="button" class="gainage-gallery-desktop__arrow gainage-gallery-desktop__arrow--prev" data-gallery-prev aria-label="Previous image">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button type="button" class="gainage-gallery-desktop__arrow gainage-gallery-desktop__arrow--next" data-gallery-next aria-label="Next image">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    <!-- Thumbnails -->
    <div class="gainage-gallery-desktop__thumbs">
      {%- for media in product.media -%}
        {%- if media.media_type == 'image' -%}
          <button
            type="button"
            class="gainage-gallery-desktop__thumb{% if forloop.first %} is-active{% endif %}"
            data-thumb-index="{{ forloop.index0 }}"
            aria-label="View image {{ forloop.index }}"
          >
            <img
              src="{{ media | image_url: width: 160 }}"
              srcset="{{ media | image_url: width: 160 }} 160w,
                      {{ media | image_url: width: 320 }} 320w"
              sizes="80px"
              alt=""
              width="160"
              height="{{ 160 | divided_by: media.aspect_ratio | round }}"
              loading="lazy"
            >
          </button>
        {%- endif -%}
      {%- endfor -%}
    </div>
  {%- endif -%}
</div>
