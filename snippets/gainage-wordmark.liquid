{%- comment -%}
  GAINAGE wordmark
  Usage: {% render 'gainage-wordmark' %}

  Uses the tight-crop SVG (648×198) — no whitespace, no clipping needed.
{%- endcomment -%}

<div class="gainage-wordmark">
  <a href="{{ routes.root_url }}" class="gainage-wordmark__link" aria-label="GAINAGE — Home">
    <img
      src="{{ 'GAINAGE WORD MARK.svg' | asset_url }}"
      alt="GAINAGE"
      class="gainage-wordmark__logo"
      width="160"
      height="49"
      loading="eager"
    >
  </a>
</div>

<style>
  .gainage-wordmark__link {
    text-decoration: none;
    display: block;
  }

  .gainage-wordmark__logo {
    width: 160px;
    height: auto;
    display: block;
  }
</style>
