{%- comment -%}
  GAINAGE wordmark + tagline
  Usage: {% render 'gainage-wordmark', show_tagline: true %}
{%- endcomment -%}

{%- assign show_tagline = show_tagline | default: false -%}

<div class="gainage-wordmark">
  <a href="{{ routes.root_url }}" class="gainage-wordmark__link" aria-label="GAINAGE — Home">
    <img
      src="{{ 'GAINAGE Classic LOGO white .svg' | asset_url }}"
      alt="GAINAGE"
      class="gainage-wordmark__logo"
      width="210"
      height="175"
      loading="eager"
    >
  </a>
  {%- if show_tagline -%}
    <span class="gainage-wordmark__tagline g-body">A SEVERE ADDICTION TO PROGRESS</span>
  {%- endif -%}
</div>

<style>
  .gainage-wordmark {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .gainage-wordmark__link {
    text-decoration: none;
    display: block;
  }

  .gainage-wordmark__logo {
    width: 210px;
    height: auto;
    display: block;
  }

  .gainage-wordmark__tagline {
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--g-color-text);
    opacity: 0.9;
  }
</style>
