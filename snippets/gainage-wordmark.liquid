{%- comment -%}
  GAINAGE wordmark
  Usage: {% render 'gainage-wordmark' %}

  The SVG (864x720) contains the full logo with tagline.
  We use CSS background-image so we can control the rendered size and crop
  precisely, avoiding browser quirks with absolutely-positioned <img>.

  background-size: 210px 175px  → renders SVG at this display size
  background-position: -44px -69px → shifts so G aligns to left edge,
                                      and text Y-band (display y 76-102) is centred
  Container: 165px wide x 44px tall → clips to GAINAGE text only
{%- endcomment -%}

<div class="gainage-wordmark">
  <a href="{{ routes.root_url }}" class="gainage-wordmark__link" aria-label="GAINAGE — Home">
    <div
      class="gainage-wordmark__bg"
      style="background-image: url('{{ 'GAINAGE Classic LOGO white .svg' | asset_url }}');"
      role="img"
      aria-label="GAINAGE"
    ></div>
  </a>
</div>

<style>
  .gainage-wordmark__link {
    text-decoration: none;
    display: block;
  }

  .gainage-wordmark__bg {
    width: 165px;
    height: 44px;
    background-size: 210px 175px;
    background-repeat: no-repeat;
    background-position: -44px -69px;
  }
</style>
