{%- comment -%}
  GAINAGE Buy Form — ATC form with hidden variant input
  Usage: {% render 'gainage-buy-form', product: product %}
{%- endcomment -%}

{%- form 'product', product, class: 'gainage-buy-form', data-buy-form: '', novalidate: 'novalidate' -%}
  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-input>

  <div class="gainage-qty">
    <button type="button" class="gainage-qty__btn g-display" data-qty-minus aria-label="Decrease quantity">−</button>
    <input
      type="number"
      name="quantity"
      value="1"
      min="1"
      class="gainage-qty__input g-display"
      aria-label="Quantity"
    >
    <button type="button" class="gainage-qty__btn g-display" data-qty-plus aria-label="Increase quantity">+</button>
  </div>

  <div class="gainage-buy-form__actions">
    <button
      type="submit"
      class="gainage-buy-form__submit g-display"
      {% if product.available %}disabled aria-disabled="true"{% else %}disabled aria-disabled="true"{% endif %}
    >
      {%- if product.available -%}
        CHOOSE SIZE
      {%- else -%}
        SOLD OUT
      {%- endif -%}
    </button>

    {%- if product.available -%}
      <div class="gainage-buy-form__dynamic-checkout">
        {{ form | payment_button }}
      </div>
    {%- endif -%}
  </div>

  <div class="gainage-buy-form__trust">
    <span class="gainage-buy-form__trust-item g-body">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.91a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/>
        <path d="M14.05 2a9 9 0 0 1 8 7.94"/>
        <path d="M14.05 6A5 5 0 0 1 18 10"/>
      </svg>
      WORLDWIDE SHIPPING
    </span>
    <span class="gainage-buy-form__trust-item g-body">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      </svg>
      SECURE CHECKOUT
    </span>
  </div>

  <div class="gainage-buy-form__links">
    <a href="/pages/size-chart" class="gainage-buy-form__link g-display">SIZE CHART</a>
    <a href="/policies/shipping-policy" class="gainage-buy-form__link g-display">SHIPPING POLICY</a>
  </div>
{%- endform -%}
