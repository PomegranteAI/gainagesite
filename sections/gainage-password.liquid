{%- comment -%}
  GAINAGE Password / Coming Soon Page
  Full-viewport centered layout with wordmark, iteration heading, email form, and password link
{%- endcomment -%}

<div class="gainage-password" id="gainage-password">
  <div class="gainage-password__content">
    <!-- Wordmark -->
    <h1 class="gainage-password__wordmark">
      <img src="{{ 'SIMPLE CLEAN LOGO.svg' | asset_url }}" alt="GAINAGE" class="gainage-password__wordmark-img" width="300" height="34" loading="eager">
    </h1>

    <!-- Iteration heading -->
    <p class="gainage-password__heading g-body">
      SIGN UP FOR ITERATION : <span class="gainage-password__iteration">{{ section.settings.iteration_label }}</span>
    </p>

    <!-- Email signup form -->
    {%- form 'customer', class: 'gainage-password__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter,{{ section.settings.iteration_label }}">
      <div class="gainage-password__form-row">
        <div class="gainage-password__input-wrap">
          <label for="gainage-email" class="g-sr-only">Your e-mail</label>
          <input
            type="email"
            name="contact[email]"
            id="gainage-email"
            class="gainage-password__input g-body"
            placeholder="YOUR E-MAIL"
            autocomplete="email"
            required
          >
        </div>
        <button type="submit" class="gainage-password__submit g-display">
          SIGN UP
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="gainage-password__success g-body">Thank you for signing up.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="gainage-password__error g-body">{{ form.errors.messages['email'] }}</p>
      {%- endif -%}
    {%- endform -%}

    <!-- Password access link -->
    <button
      class="gainage-password__access-link g-body"
      type="button"
      aria-haspopup="dialog"
      data-password-modal-toggle
    >
      CLICK FOR PASSWORD ACCESS
    </button>
  </div>

  <!-- Password modal (Shopify native) -->
  <details-modal class="gainage-password-modal">
    <details>
      <summary class="g-sr-only">Enter store password</summary>
      <div class="gainage-password-modal__overlay" data-password-modal-toggle></div>
      <div class="gainage-password-modal__dialog" role="dialog" aria-label="Enter store password">
        <button class="gainage-password-modal__close" type="button" data-password-modal-toggle aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" y1="4" x2="16" y2="16"/><line x1="16" y1="4" x2="4" y2="16"/>
          </svg>
        </button>
        <h2 class="gainage-password-modal__title g-display">ENTER PASSWORD</h2>
        {%- form 'storefront_password', class: 'gainage-password-modal__form' -%}
          <div class="gainage-password-modal__field">
            <label for="gainage-store-password" class="g-sr-only">Password</label>
            <input
              type="password"
              name="password"
              id="gainage-store-password"
              class="gainage-password-modal__input g-body"
              placeholder="PASSWORD"
              autocomplete="current-password"
            >
          </div>
          <button type="submit" class="gainage-password-modal__submit g-display">ENTER</button>
          {%- if form.errors -%}
            <p class="gainage-password-modal__error g-body">Wrong password.</p>
          {%- endif -%}
        {%- endform -%}
      </div>
    </details>
  </details-modal>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toggles = document.querySelectorAll('[data-password-modal-toggle]');
    const details = document.querySelector('.gainage-password-modal details');

    const summary = details.querySelector('summary');

    function openModal() {
      details.setAttribute('open', '');
      var input = details.querySelector('input[type="password"]');
      if (input) input.focus();
    }

    function closeModal(e) {
      if (e) e.stopPropagation();
      details.removeAttribute('open');
      details.open = false;
    }

    toggles.forEach(function (toggle) {
      toggle.addEventListener('click', function (e) {
        if (details.open) {
          closeModal(e);
        } else {
          openModal();
        }
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && details.open) {
        closeModal();
      }
    });

    {%- if form.errors -%}
      if (details) details.setAttribute('open', '');
    {%- endif -%}
  });
</script>

{% schema %}
{
  "name": "GAINAGE Password",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "iteration_label",
      "label": "Iteration number",
      "default": "001",
      "info": "Displayed as 'SIGN UP FOR ITERATION : [number]'"
    }
  ]
}
{% endschema %}
