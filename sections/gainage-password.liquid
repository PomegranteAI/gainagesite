{%- comment -%}
  GAINAGE Password / Coming Soon Page
  Full-viewport centered layout with wordmark, iteration heading, email form, and password link
{%- endcomment -%}

<div class="gainage-password" id="gainage-password">

  {%- if section.blocks.size > 0 -%}
  <div class="gainage-pw-carousel" data-pw-carousel>
    <button type="button" class="gainage-pw-carousel__arrow" data-pw-prev aria-label="Previous product">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="gainage-pw-carousel__slides">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product_image' and block.settings.image -%}
          <div class="gainage-pw-carousel__slide{% if forloop.first %} is-active{% endif %}" {{ block.shopify_attributes }}>
            <img
              src="{{ block.settings.image | image_url: width: 600 }}"
              alt="{{ block.settings.image.alt | default: 'GAINAGE product' }}"
              width="600"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            >
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <button type="button" class="gainage-pw-carousel__arrow" data-pw-next aria-label="Next product">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>
  {%- endif -%}

  <div class="gainage-password__content">
    <!-- Wordmark -->
    <h1 class="gainage-password__wordmark">
      <img src="{{ 'SIMPLE CLEAN LOGO.svg' | asset_url }}" alt="GAINAGE" class="gainage-password__wordmark-img" width="300" height="34" loading="eager">
    </h1>

    <!-- Iteration heading -->
    <p class="gainage-password__heading g-body">
      SIGN UP FOR ITERATION : <span class="gainage-password__iteration">{{ section.settings.iteration_label }}</span>
    </p>

    <!-- Email signup form -->
    {%- form 'customer', class: 'gainage-password__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter,{{ section.settings.iteration_label }}">
      <div class="gainage-password__form-row">
        <div class="gainage-password__input-wrap">
          <label for="gainage-email" class="g-sr-only">Your e-mail</label>
          <input
            type="email"
            name="contact[email]"
            id="gainage-email"
            class="gainage-password__input g-body"
            placeholder="YOUR E-MAIL"
            autocomplete="email"
            required
          >
        </div>
        <button type="submit" class="gainage-password__submit g-display">
          SIGN UP
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="gainage-password__success g-body">Thank you for signing up.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="gainage-password__error g-body">{{ form.errors.messages['email'] }}</p>
      {%- endif -%}
    {%- endform -%}

    <!-- Password access link -->
    <button
      class="gainage-password__access-link g-body"
      type="button"
      aria-haspopup="dialog"
      data-password-modal-toggle
    >
      CLICK FOR PASSWORD ACCESS
    </button>
  </div>

  <!-- Password modal -->
  <div class="gainage-password-modal" id="gainage-password-modal" aria-hidden="true" role="dialog" aria-label="Enter store password" aria-modal="true">
    <div class="gainage-password-modal__overlay" data-password-modal-close></div>
    <div class="gainage-password-modal__dialog">
      <button class="gainage-password-modal__close" type="button" data-password-modal-close aria-label="Close">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="4" x2="16" y2="16"/><line x1="16" y1="4" x2="4" y2="16"/>
        </svg>
      </button>
      <h2 class="gainage-password-modal__title g-display">ENTER PASSWORD</h2>
      {%- form 'storefront_password', class: 'gainage-password-modal__form' -%}
        <div class="gainage-password-modal__field">
          <label for="gainage-store-password" class="g-sr-only">Password</label>
          <input
            type="password"
            name="password"
            id="gainage-store-password"
            class="gainage-password-modal__input g-body"
            placeholder="PASSWORD"
            autocomplete="current-password"
          >
        </div>
        <button type="submit" class="gainage-password-modal__submit g-display">ENTER</button>
        {%- if form.errors -%}
          <p class="gainage-password-modal__error g-body">Wrong password.</p>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var modal   = document.getElementById('gainage-password-modal');
    var openBtn = document.querySelector('[data-password-modal-toggle]');
    var closeBtns = document.querySelectorAll('[data-password-modal-close]');

    function openModal() {
      modal.classList.add('is-open');
      modal.setAttribute('aria-hidden', 'false');
      var input = modal.querySelector('input[type="password"]');
      if (input) setTimeout(function () { input.focus(); }, 50);
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
    }

    if (openBtn) openBtn.addEventListener('click', openModal);

    closeBtns.forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.stopPropagation();
        closeModal();
      });
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
    });

    {%- if form.errors -%}
      if (modal) { modal.classList.add('is-open'); modal.setAttribute('aria-hidden', 'false'); }
    {%- endif -%}

    // Product carousel
    var carousel = document.querySelector('[data-pw-carousel]');
    if (carousel) {
      var slides = carousel.querySelectorAll('.gainage-pw-carousel__slide');
      var current = 0;

      function showSlide(index) {
        slides[current].classList.remove('is-active');
        current = (index + slides.length) % slides.length;
        slides[current].classList.add('is-active');
      }

      carousel.querySelector('[data-pw-prev]').addEventListener('click', function () {
        showSlide(current - 1);
      });
      carousel.querySelector('[data-pw-next]').addEventListener('click', function () {
        showSlide(current + 1);
      });
    }
  });
</script>

{% schema %}
{
  "name": "GAINAGE Password",
  "tag": "section",
  "blocks": [
    {
      "type": "product_image",
      "name": "Product Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "text",
      "id": "iteration_label",
      "label": "Iteration number",
      "default": "001",
      "info": "Displayed as 'SIGN UP FOR ITERATION : [number]'"
    }
  ]
}
{% endschema %}
