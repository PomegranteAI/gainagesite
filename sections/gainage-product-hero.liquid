{%- comment -%}
  GAINAGE Product Hero — Gallery left, info right
{%- endcomment -%}

{{ 'gainage-product-hero.css' | asset_url | stylesheet_tag }}

<div class="gainage-product" data-product-section>
  <!-- Gallery -->
  <div class="gainage-product__gallery">
    <div class="gainage-product__gallery-desktop">
      {% render 'gainage-gallery-desktop', product: product %}
    </div>
    <div class="gainage-product__gallery-mobile">
      {% render 'gainage-gallery-mobile', product: product %}
    </div>
  </div>

  <!-- Info -->
  <div class="gainage-product__info">
    <h1 class="gainage-product__title g-display">{{ product.title }}</h1>

    <p class="gainage-product__price g-display">
      {{ product.price | money }}
    </p>

    <!-- Stock indicator -->
    <div class="gainage-stock" data-stock-indicator aria-live="polite">
      <span class="gainage-stock__dot-wrap">
        <span class="gainage-stock__dot"></span>
        <span class="gainage-stock__ring"></span>
      </span>
      <span class="gainage-stock__label g-body" data-stock-label></span>
    </div>

    {% render 'gainage-product-specs', product: product %}

    {% render 'gainage-size-selector', product: product %}

    <!-- Variant inventory data -->
    <script type="application/json" id="gainage-variant-data">
      [
        {%- for variant in product.variants -%}
        {
          "id": {{ variant.id }},
          "available": {{ variant.available }},
          "inventory_quantity": {{ variant.inventory_quantity }},
          "inventory_management": {{ variant.inventory_management | json }}
        }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      ]
    </script>

    {% render 'gainage-buy-form', product: product %}
  </div>
</div>

<script src="{{ 'gainage-gallery.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'gainage-size-selector.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'gainage-buy-form.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "GAINAGE Product Hero",
  "tag": "section",
  "settings": []
}
{% endschema %}
