{%- comment -%}
  GAINAGE Full Cart Page
{%- endcomment -%}

{{ 'gainage-cart-page.css' | asset_url | stylesheet_tag }}

<div class="gainage-cart-page">
  <h1 class="gainage-cart-page__title g-display">YOUR CART</h1>

  {%- if cart.item_count > 0 -%}
    <div class="gainage-cart-page__items" data-cart-items>
      {%- for item in cart.items -%}
        <div class="gainage-cart-page__item" data-line-item data-line-key="{{ item.key }}">
          <div class="gainage-cart-page__item-image">
            {%- if item.image -%}
              <a href="{{ item.url }}">
                <img
                  src="{{ item.image | image_url: width: 240 }}"
                  alt="{{ item.image.alt | escape | default: item.product.title }}"
                  width="240"
                  height="{{ 240 | divided_by: item.image.aspect_ratio | round }}"
                  loading="lazy"
                >
              </a>
            {%- endif -%}
          </div>
          <div class="gainage-cart-page__item-details">
            <a href="{{ item.url }}" class="gainage-cart-page__item-title g-display">{{ item.product.title }}</a>
            {%- if item.product.metafields.custom.iteration != blank -%}
              <p class="gainage-cart-page__item-meta g-body">{{ item.product.metafields.custom.iteration }}</p>
            {%- endif -%}
            {%- unless item.variant.title == 'Default Title' -%}
              <p class="gainage-cart-page__item-variant g-display">{{ item.variant.title }}</p>
            {%- endunless -%}
          </div>
          <div class="gainage-cart-page__item-qty">
            <button type="button" class="gainage-cart-page__qty-btn g-display" data-qty-minus data-line-key="{{ item.key }}">-</button>
            <span class="gainage-cart-page__qty-value g-display" data-qty-value>{{ item.quantity }}</span>
            <button type="button" class="gainage-cart-page__qty-btn g-display" data-qty-plus data-line-key="{{ item.key }}">+</button>
          </div>
          <div class="gainage-cart-page__item-price">
            <span class="g-display">{{ item.final_line_price | money_without_trailing_zeros }}</span>
          </div>
          <button type="button" class="gainage-cart-page__item-remove g-body" data-qty-remove data-line-key="{{ item.key }}" aria-label="Remove {{ item.product.title }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="4" y1="4" x2="16" y2="16"/><line x1="16" y1="4" x2="4" y2="16"/></svg>
          </button>
        </div>
      {%- endfor -%}
    </div>

    {% render 'gainage-free-shipping-bar', cart: cart, threshold: section.settings.free_shipping_threshold %}

    <div class="gainage-cart-page__footer">
      <div class="gainage-cart-page__subtotal">
        <span class="g-display">SUBTOTAL</span>
        <span class="gainage-cart-page__subtotal-value g-display" data-cart-subtotal>{{ cart.total_price | money_without_trailing_zeros }}</span>
      </div>

      <label class="gainage-cart-page__terms">
        <input type="checkbox" class="gainage-cart-page__terms-check" data-terms-check>
        <span class="g-display">I AGREE TO THE TERMS AND CONDITIONS</span>
      </label>

      <a href="/checkout" class="gainage-cart-page__checkout g-display" data-checkout-btn aria-disabled="true">CHECKOUT</a>
    </div>
  {%- else -%}
    <div class="gainage-cart-page__empty">
      <p class="gainage-cart-page__empty-text g-display">YOUR CART IS EMPTY</p>
      <a href="/collections/{{ section.settings.iteration_handle | default: 'all' }}" class="gainage-cart-page__empty-link g-display">CONTINUE SHOPPING</a>
    </div>
  {%- endif -%}
</div>

<script src="{{ 'gainage-cart-page.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "GAINAGE Cart Page",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "free_shipping_threshold",
      "min": 0,
      "max": 200,
      "step": 5,
      "default": 50,
      "unit": "£",
      "label": "Free shipping threshold"
    },
    {
      "type": "text",
      "id": "iteration_handle",
      "label": "Default collection handle",
      "default": "iteration-001"
    }
  ]
}
{% endschema %}
