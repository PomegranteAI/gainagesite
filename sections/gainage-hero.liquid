{%- comment -%}
  GAINAGE Hero — Full-bleed image/banner with optional overlay heading + CTA
{%- endcomment -%}

{{ 'gainage-hero.css' | asset_url | stylesheet_tag }}

<div class="gainage-hero">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 1600 }}"
      alt="{{ section.settings.image.alt | escape | default: 'Hero banner' }}"
      width="1600"
      height="{{ 1600 | divided_by: section.settings.image.aspect_ratio | round }}"
      class="gainage-hero__image"
      loading="eager"
      fetchpriority="high"
    >
  {%- else -%}
    <div class="gainage-hero__placeholder">
      {{ 'lifestyle-1' | placeholder_svg_tag }}
    </div>
  {%- endif -%}

  {%- if section.settings.heading != blank or section.settings.cta_text != blank -%}
    <div class="gainage-hero__overlay">
      {%- if section.settings.heading != blank -%}
        <h2 class="gainage-hero__heading g-display">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.cta_text != blank and section.settings.cta_link != blank -%}
        <a href="{{ section.settings.cta_link }}" class="gainage-hero__cta g-display">{{ section.settings.cta_text }}</a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "GAINAGE Hero",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": ""
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "GAINAGE Hero"
    }
  ]
}
{% endschema %}
